# Production Environment Variables
# Copy ke .env dan update dengan nilai production

# Project Configuration
PROJECT_NAME=Warehouse Packing Proof Recording System

# Database Configuration - UPDATE UNTUK PRODUCTION
# Format: mysql+aiomysql://username:password@host:port/database
DATABASE_URL=mysql+aiomysql://root:YOUR_PASSWORD_HERE@localhost:3306/recorderd

# JWT Configuration
# PENTING: Generate random secret untuk production
# Bisa generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-production-secret-key-change-this

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Video Storage Path
VIDEO_STORAGE_PATH=/var/recorderd/videos

# Optional: Enable debug logging
# DEBUG=false
