# Production Environment Variables
# Copy ke .env dan update dengan nilai production

# Project Configuration
PROJECT_NAME=Packing Proof Recording System

# Database Configuration
# Priority is given to DATABASE_URL if set.
# Otherwise, it constructs the URL from individual DB_* variables.
DATABASE_URL=mysql+aiomysql://root:admin@localhost:3306/rec
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rec

# JWT Configuration
# PENTING: Generate random secret untuk production
# Bisa generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Video Storage Path
VIDEO_STORAGE_PATH=/home/alwizen/Workspace/py/recorderd/videos

# Optional: Enable debug logging
# DEBUG=false
#/home/alwizen/Workspace/py/recorderd/videos